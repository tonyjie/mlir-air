# Persistent build artifacts (kernel caches, external_kernels/*.o):
# all under build/. Single rm rule in the Makefile cleans this whole tree.
build/

# Transient aircc working dir + per-compile leftovers (must live at CWD
# because aiecc generates linker scripts with hardcoded `INPUT(air_project/...)`).
air_project/
air.elf
air.mlir
air.xclbin
air.insts.bin

# Python
__pycache__/
*.pyc
